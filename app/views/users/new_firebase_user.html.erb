<!DOCTYPE html>
<html>
<head>
  <meta name="viewport" content="width=device-width,initial-scale=1">

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">

  <style>
    :root {
      --primary: #4361ee;
      --accent: #7c3aed;
      --text: #ffffff;
      --text-muted: rgba(255,255,255,0.75);
    }

    body {
      margin: 0;
      min-height: 100vh;
      font-family: 'Segoe UI', system-ui, sans-serif;
      color: var(--text);
      background: url("/istockphoto-2163983591-612x612.jpg") center/cover no-repeat fixed;
      position: relative;
    }

    body::before {
      content: "";
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.65);
      backdrop-filter: blur(6px);
      z-index: -1;
    }

    .navbar-custom {
      background: rgba(0,0,0,0.55);
      backdrop-filter: blur(20px);
      border-bottom: 1px solid rgba(255,255,255,0.1);
    }

    .navbar-brand-custom {
      font-weight: 700;
      font-size: 1.4rem;
      background: linear-gradient(135deg, var(--primary), var(--accent));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .nav-link-custom {
      color: var(--text-muted) !important;
      padding: .5rem 1rem;
      border-radius: .6rem;
      transition: all .25s ease;
      font-weight: 500;
    }

    .nav-link-custom:hover {
      color: #fff !important;
      background: linear-gradient(135deg, var(--primary), var(--accent));
    }

    .glass-card {
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.15);
      border-radius: 1.2rem;
      backdrop-filter: blur(20px);
      box-shadow: 0 25px 50px rgba(0,0,0,0.6);
    }

    .card-header-custom {
      background: linear-gradient(135deg, rgba(67,97,238,0.25), rgba(124,58,237,0.25));
      border-bottom: 1px solid rgba(255,255,255,0.15);
      border-radius: 1.2rem 1.2rem 0 0;
      padding: 1.5rem;
    }

    .form-label {
      font-weight: 600;
      color: #fff;
    }

    .form-control {
      background: rgba(255,255,255,0.1);
      border: 1px solid rgba(255,255,255,0.2);
      color: #fff;
      border-radius: .7rem;
    }

    .form-control:focus {
      background: rgba(255,255,255,0.15);
      border-color: var(--primary);
      box-shadow: 0 0 0 3px rgba(67,97,238,0.35);
      color: #fff;
    }

    .btn-primary-custom {
      background: linear-gradient(135deg, var(--primary), var(--accent));
      border: none;
      padding: .8rem 2rem;
      border-radius: .7rem;
      color: #fff;
      font-weight: 600;
    }

    .btn-secondary-custom {
      background: rgba(255,255,255,0.2);
      border: none;
      padding: .8rem 2rem;
      border-radius: .7rem;
      color: #fff;
      font-weight: 600;
      text-decoration: none;
    }

  </style>
</head>

<body>

<!-- NAVBAR -->
<nav class="navbar navbar-expand-lg navbar-custom sticky-top">
  <div class="container">
    <a class="navbar-brand-custom" href="<%= root_path %>">
      <i class="fas fa-database me-2"></i>Firebase Manager
    </a>

    <div class="ms-auto">
      <%= link_to users_path, class: "nav-link-custom" do %>
        <i class="fas fa-arrow-left me-1"></i> Back
      <% end %>
    </div>
  </div>
</nav>


<!-- MAIN CONTENT -->
<div class="container py-5">

  <div class="row justify-content-center">

    <div class="col-md-6">

      <div class="glass-card">

        <div class="card-header-custom">
          <h4>
            <i class="fas fa-user-plus me-2"></i>
            Add User to Firebase
          </h4>
        </div>

        <div class="p-4">

          <%= form_with url: create_in_firebase_users_path, method: :post, local: true do %>

            <div class="mb-3">
              <label class="form-label">
                <i class="fas fa-user me-1"></i> Name
              </label>

              <%= text_field_tag :name, nil,
                  class: "form-control",
                  placeholder: "Enter user name",
                  required: true %>
            </div>

            <div class="mb-4">
              <label class="form-label">
                <i class="fas fa-envelope me-1"></i> Email
              </label>

              <%= email_field_tag :email, nil,
                  class: "form-control",
                  placeholder: "Enter user email",
                  required: true %>
            </div>

            <div class="d-flex justify-content-between">

              <%= link_to users_path, class: "btn-secondary-custom" do %>
                <i class="fas fa-arrow-left me-1"></i>
                Back
              <% end %>

              <%= submit_tag "Create User",
                  class: "btn-primary-custom" %>

            </div>

          <% end %>

        </div>

      </div>

    </div>

  </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
