<!DOCTYPE html>
<html>
<head>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">

  <style>
    :root {
      --primary: #4361ee;
      --accent: #7c3aed;
      --text: #ffffff;
      --text-muted: rgba(255,255,255,0.75);
    }

    body {
      margin: 0;
      min-height: 100vh;
      font-family: 'Segoe UI', system-ui, sans-serif;
      color: var(--text);
      background: url("/istockphoto-2163983591-612x612.jpg") center/cover no-repeat fixed;
      position: relative;
    }

    body::before {
      content: "";
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.65);
      backdrop-filter: blur(6px);
      z-index: -1;
    }

    .navbar-custom {
      background: rgba(0,0,0,0.55);
      backdrop-filter: blur(20px);
      border-bottom: 1px solid rgba(255,255,255,0.1);
    }

    .navbar-brand-custom {
      font-weight: 700;
      font-size: 1.4rem;
      background: linear-gradient(135deg, var(--primary), var(--accent));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .nav-link-custom {
      color: var(--text-muted) !important;
      padding: .5rem 1rem;
      border-radius: .6rem;
      transition: .25s;
      font-weight: 500;
    }

    .nav-link-custom:hover {
      color: #fff !important;
      background: linear-gradient(135deg, var(--primary), var(--accent));
    }

    .glass-card {
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.15);
      border-radius: 1.2rem;
      backdrop-filter: blur(20px);
      box-shadow: 0 25px 50px rgba(0,0,0,0.6);
      animation: fadeUp .6s ease;
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .card-header-custom {
      background: linear-gradient(135deg, rgba(67,97,238,0.25), rgba(124,58,237,0.25));
      border-bottom: 1px solid rgba(255,255,255,0.15);
      border-radius: 1.2rem 1.2rem 0 0;
      padding: 1.5rem;
    }

    .recipient-list {
      max-height: 250px;
      overflow-y: auto;
      padding: 1rem;
      background: rgba(0,0,0,0.3);
      border-radius: .8rem;
      border: 1px solid rgba(255,255,255,0.1);
    }

    .recipient-list::-webkit-scrollbar {
      width: 6px;
    }

    .recipient-list::-webkit-scrollbar-thumb {
      background: var(--primary);
      border-radius: 3px;
    }

    .form-control {
      background: rgba(255,255,255,0.1);
      border: 1px solid rgba(255,255,255,0.2);
      color: #fff;
      border-radius: .7rem;
    }

    .form-control:focus {
      border-color: var(--primary);
      box-shadow: 0 0 0 3px rgba(67,97,238,0.35);
      color: #fff;
    }

    .btn-send {
      background: linear-gradient(135deg, var(--primary), var(--accent));
      border: none;
      color: #fff;
      padding: .9rem 2.8rem;
      font-weight: 600;
      border-radius: .8rem;
      transition: .3s;
      box-shadow: 0 10px 30px rgba(67,97,238,0.4);
    }

    .btn-send:hover {
      transform: translateY(-3px);
    }

    .badge-selected {
      background: var(--primary);
      font-size: .75rem;
    }

    #userSearch {
      color: #fff;
    }

    #userSearch::placeholder {
      color: rgba(255,255,255,0.6);
    }

  </style>
</head>

<body>

<nav class="navbar navbar-expand-lg navbar-custom sticky-top">
  <div class="container">
    <a class="navbar-brand-custom" href="<%= root_path %>">
      <i class="fas fa-paper-plane me-2"></i>Mail Service
    </a>

    <div class="collapse navbar-collapse">
      <ul class="navbar-nav ms-auto gap-2">
        <li class="nav-item">
          <a class="nav-link-custom" href="<%= root_path %>">Dashboard</a>
        </li>
        <li class="nav-item">
          <a class="nav-link-custom" href="<%= new_firebase_user_users_path %>">Add User</a>
        </li>
        <li class="nav-item">
          <%= link_to logout_path,
                data: { turbo_method: :delete, turbo_confirm: "Logout?" },
                class: "nav-link-custom" do %>
            <i class="fas fa-sign-out-alt me-1"></i> Logout
          <% end %>
        </li>
      </ul>
    </div>
  </div>
</nav>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-8">
      <div class="glass-card">
        <div class="card-header-custom d-flex justify-content-between align-items-center">
          <h4><i class="fas fa-paper-plane me-2"></i>Send Email</h4>
          <span class="badge badge-selected" id="selectedCount">0 Selected</span>
        </div>

        <div class="p-4">
          <%= form_with url: send_emails_users_path, multipart: true, local: false, id: "sendEmailForm" do %>
            <!-- Search + Select All -->
            <div class="mb-3 d-flex gap-3 align-items-center">
              <input type="text" id="userSearch" class="form-control text-dark" placeholder="Search users...">
              <div class="form-check text-light">
                <input type="checkbox" id="selectAllUsers" class="form-check-input">
                <label class="form-check-label">Select All</label>
              </div>
            </div>

            <!-- User List -->
            <div class="recipient-list mb-4">
              <% @users.each do |user| %>
                <div class="form-check mb-2 user-item"
                     data-name="<%= user[:name].to_s.downcase %>"
                     data-email="<%= user[:email].downcase %>">
                  <%= check_box_tag "user_emails[]",
                                    user[:email],
                                    false,
                                    class: "form-check-input user-checkbox" %>
                  <label class="form-check-label">
                    <strong><%= user[:name] rescue "" %></strong>
                    <small class="ms-2 text-light"><%= user[:email] %></small>
                  </label>
                </div>
              <% end %>
            </div>

            <!-- Message -->
            <div class="mb-4">
              <%= text_area_tag :message, nil,
                    class: "form-control text-dark",
                    rows: 5,
                    placeholder: "Write your message..." %>
            </div>

            <!-- Attachments -->
            <div class="mb-4">
              <%= file_field_tag "attachments[]", multiple: true, class: "form-control" %>
            </div>

            <div class="text-end">
              <%= submit_tag "Send Email", class: "btn btn-send btn-lg" %>
            </div>

          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
function initUserSearch() {
  const searchInput = document.getElementById("userSearch");
  const selectAll = document.getElementById("selectAllUsers");
  const userItems = document.querySelectorAll(".user-item");
  const checkboxes = document.querySelectorAll(".user-checkbox");
  const selectedCount = document.getElementById("selectedCount");

  if (!searchInput) return; // safety check

  function updateCount() {
    const checked = document.querySelectorAll(".user-checkbox:checked").length;
    selectedCount.textContent = checked + " Selected";
  }

  // Search filter
  searchInput.addEventListener("keyup", function () {
    const query = this.value.toLowerCase();

    userItems.forEach(item => {
      const name = item.dataset.name || "";
      const email = item.dataset.email || "";
      item.style.display =
        name.includes(query) || email.includes(query) ? "block" : "none";
    });
  });

  // Select all
  selectAll.addEventListener("change", function () {
    userItems.forEach(item => {
      if (item.style.display !== "none") {
        item.querySelector(".user-checkbox").checked = this.checked;
      }
    });
    updateCount();
  });

  // Update count on individual checkbox change
  checkboxes.forEach(box => {
    box.addEventListener("change", updateCount);
  });
}

// Run on initial page load
document.addEventListener("turbo:load", initUserSearch);

</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
